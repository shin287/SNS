<h1>ログイン</h1>

<%= form_with url: login_path do |f| %>
  <div>
    <p><%= f.label :email, "メールアドレス" %></p>
    <p><%= f.email_field :email %></p>
  </div>

  <div>
    <p><%= f.label :password, "パスワード" %></p>
    <p><%= f.password_field :password %></p>
  </div>

  <div>
    <%= f.submit "ログイン" %>
  </div>
<% end %>
