<h1>おはなししよう！</h1>

<% if @post.errors.any? %>
  <div>
    <ul>
      <% @post.errors.full_messages.each do |message| %>
        <li class="error"><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @post do |f| %>
  <div class="formBox">
    <p class="new"><%= f.label :content, "おはなし" %></p>
    <p class="newText"><%= f.text_area :content, class: "newPost" %></p>
  </div>

  <div>
    <%= f.submit "これでけってい！", class: "btn" %>
  </div>
<% end %>

<%= link_to "もどる", posts_path, class: "back" %>
