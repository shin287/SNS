<h1>みんなのおはなし</h1>

<% @posts.each do |post| %>
  <%= link_to post_path(post) do %>
    <div class="indexPost">
      <p><%= post.user.name %></p>
      <p><%= post.content %></p>
    </div>
  <% end %>
<% end %>

<% if current_user %>
  <%= link_to "自分もおはなしする！", new_post_path, class: "btn" %>
<% else %>
  <%= link_to "ログインしておはなしする！", login_path, class: "btn" %>
<% end %>
